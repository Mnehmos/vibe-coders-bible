---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = "The Vibe Coder's Bible", description = "A trust-but-verify field manual for AI-assisted software development." } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
</head>
<body class="min-h-screen flex flex-col">
  <header class="sticky top-0 z-50 border-b border-[#2a2a2a] bg-[#0d0d0d]/95 backdrop-blur">
    <div class="max-w-7xl mx-auto px-4 h-14 flex items-center justify-between gap-4">
      <a href={base} class="font-mono text-sm text-amber-400 hover:text-amber-300 transition-colors shrink-0">
        The Vibe Coder's Bible
      </a>
      <nav class="flex items-center gap-1 text-sm overflow-x-auto">
        <a href={`${base}/chapters`} class="px-3 py-1.5 text-[#777] hover:text-[#e2e2e2] transition-colors whitespace-nowrap">Chapters</a>
        <a href={`${base}/doctrine`} class="px-3 py-1.5 text-[#777] hover:text-[#e2e2e2] transition-colors whitespace-nowrap">Doctrine</a>
        <a href={`${base}/search`} class="px-3 py-1.5 text-[#777] hover:text-[#e2e2e2] transition-colors whitespace-nowrap">Ask the Book</a>
        <a
          href="https://github.com/Mnehmos/vibe-coders-bible"
          target="_blank"
          rel="noopener"
          class="ml-2 px-3 py-1.5 border border-[#2a2a2a] rounded text-[#777] hover:border-amber-500 hover:text-amber-400 transition-colors whitespace-nowrap text-xs"
        >
          GitHub
        </a>
      </nav>
    </div>
  </header>

  <main class="flex-1">
    <slot />
  </main>

  <footer class="border-t border-[#2a2a2a] py-8 mt-16">
    <div class="max-w-7xl mx-auto px-4 text-center text-sm text-[#777]">
      <p class="font-mono text-amber-400/60 mb-2">Trust AI to propose. Verify before commit.</p>
      <p>
        The Vibe Coder's Bible by <a href="https://github.com/Mnehmos" class="hover:text-[#e2e2e2] transition-colors">Mnehmos</a>
        &nbsp;·&nbsp;
        <a href="https://github.com/Mnehmos/vibe-coders-bible" class="hover:text-[#e2e2e2] transition-colors">Open source on GitHub</a>
        &nbsp;·&nbsp;
        <a href="https://creativecommons.org/licenses/by/4.0/" class="hover:text-[#e2e2e2] transition-colors">CC BY 4.0</a>
      </p>
    </div>
  </footer>
</body>
</html>
